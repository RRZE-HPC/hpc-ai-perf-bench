# Apptainer container definition for LitGPT training benchmark
# Includes CUDA 12.1, PyTorch, InfiniBand/RDMA support, and LitGPT installed in editable mode.
#
# Build:
#   APPTAINER_CACHEDIR=/path/to/apptainer/cache apptainer build litgpt.sif litgpt.def
#
# The APPTAINER_CACHEDIR avoids filling your home directory with build cache.
# Point it to a location with sufficient storage (e.g. a scratch or project filesystem).

Bootstrap: docker
From: nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

%labels
    Maintainer <your-name>
    Description Apptainer container for Lit-GPT with InfiniBand and PyTorch support

%environment
    export PYTHONUNBUFFERED=1
    export DEBIAN_FRONTEND=noninteractive
    export PATH=/usr/local/bin:$PATH

%post
    # System dependencies
    apt-get update && apt-get install -y \
        git \
        wget \
        curl \
        python3 \
        python3-pip \
        python3-dev \
        python3-venv \
        build-essential \
        libglib2.0-0 \
        libxext6 \
        libsm6 \
        libxrender1 \
        libssl-dev \
        rdma-core \
        libibverbs1 \
        ibverbs-providers \
        librdmacm1 \
        libibverbs-dev \
        librdmacm-dev \
        libnl-3-200 \
        libnl-route-3-200 \
        libnl-3-dev \
        libnl-route-3-dev \
        infiniband-diags \
        ibverbs-utils \
        && apt-get clean

    # Symlink for python/pip
    ln -s /usr/bin/python3 /usr/local/bin/python
    ln -s /usr/bin/pip3 /usr/local/bin/pip

    # Upgrade pip and setuptools
    pip install --upgrade pip setuptools wheel

    # Install PyTorch (change version as needed)
    pip install torch

    # Create directory for Lit-GPT source
    mkdir -p /workspace/litgpt

%files
    ./litgpt /workspace/litgpt

%post
    # Install litgpt in editable mode with all extras
    pip install -e /workspace/litgpt[all]

%runscript
    exec python "$@"
