# Use this for AMD GPU
# Apptainer container definition for LitGPT training benchmark
# Includes rocm-7.1, pytorch-2.7.1 and LitGPT installed in editable mode.
#
# Build:
#   APPTAINER_CACHEDIR=/path/to/apptainer/cache apptainer build litgpt_amd.sif litgpt_amd.def
#
# The APPTAINER_CACHEDIR avoids filling your home directory with build cache.
# Point it to a location with sufficient storage (e.g. a scratch or project filesystem).

Bootstrap: docker
From: rocm/pytorch:rocm7.1.1_ubuntu24.04_py3.12_pytorch_release_2.7.1

%labels
    Maintainer <your-name>
    Description Apptainer container for Lit-GPT with InfiniBand and PyTorch support

%environment
    export PYTHONUNBUFFERED=1
    export DEBIAN_FRONTEND=noninteractive
    # Add the venv path explicitly as /opt/conda was missing
    export PATH=/opt/venv/bin:$PATH

%post
    # Ensure we use the venv pip if it exists
    export PATH=/opt/venv/bin:$PATH

    # System dependencies
    apt-get update && apt-get install -y \
        git \
        wget \
        curl \
        python3 \
        python3-pip \
        python3-dev \
        python3-venv \
        build-essential \
        libglib2.0-0 \
        libxext6 \
        libsm6 \
        libxrender1 \
        libssl-dev \
        rdma-core \
        libibverbs1 \
        ibverbs-providers \
        librdmacm1 \
        libibverbs-dev \
        librdmacm-dev \
        libnl-3-200 \
        libnl-route-3-200 \
        libnl-3-dev \
        libnl-route-3-dev \
        infiniband-diags \
        ibverbs-utils \
        && apt-get clean

    # Upgrade pip and setuptools (pinned to avoid pkg_resources issues)
    # Explicitly use the python in the venv if available, or rely on PATH
    # We found that setuptools 82+ causes issues with litdata/pkg_resources
    # Use config so pip doesn't complain about root
    pip config set global.no-cache-dir false
    pip install --upgrade "pip<24.1" "setuptools<70.0.0" wheel

    # Install PyTorch (already in the ROCm base image — skip to avoid conflicts)
    # pip install torch

    # Create directory for Lit-GPT source
    mkdir -p /workspace/litgpt

%files
    ./litgpt /workspace/litgpt

%post
    # Install litgpt in editable mode with all extras
    pip install -e /workspace/litgpt[all]

%runscript
    exec python "$@"
