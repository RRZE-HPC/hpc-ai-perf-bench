Bootstrap: docker
From: rocm/pytorch:rocm7.1.1_ubuntu24.04_py3.12_pytorch_release_2.9.1

%files
    requirements_amd.txt /

%post
    apt install -y python3 python3-pip rdma-core libibverbs1
    pip3 install -U xformers torchvision --index-url https://download.pytorch.org/whl/rocm7.1
    pip3 install -r /requirements_amd.txt

    # Verify xformers installation
    python3 -c "import xformers; print(f'xformers version: {xformers.__version__}')" || echo "xformers import failed"

%labels
    Maintainer "NHR@FAU"
    Version 1.1
    Description "AMD ROCm 7.1 PyTorch Container with GPU Support and xFormers"

%runscript
    # Execute python script passed as arguments
    exec python3 "$@"

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    # Define runtime library path - LLVM and ROCm are key. Base image should handle PyTorch.
    export LD_LIBRARY_PATH=/usr/lib/llvm-17/lib:/opt/rocm/lib:${LD_LIBRARY_PATH}
    # Append ROCm bin to PATH
    export PATH=/opt/rocm/bin:${PATH}
    export PYTHONUNBUFFERED=1
    export MIOPEN_DISABLE_CACHE=true

    # Add OpenMPI support (Optional, depends on cluster configuration)
    export PATH="/apps/SPACK/0.23.1/opt/linux-ubuntu24.04-x86_64_v3/gcc-13.3.0/openmpi-5.0.5-dgprja75do5kyxfsurjxcb5dvbdcks3c/bin:$PATH"
    export LD_LIBRARY_PATH="/apps/SPACK/0.23.1/opt/linux-ubuntu24.04-x86_64_v3/gcc-13.3.0/openmpi-5.0.5-dgprja75do5kyxfsurjxcb5dvbdcks3c/lib:$LD_LIBRARY_PATH"


# Build the container (located in computer vision directory)
# apptainer build save_path/amd_rocm6_3_xformers.sif scripts/environment/amd_rocm6_3_xformers.def
