Bootstrap: docker
From: nvcr.io/nvidia/pytorch:25.05-py3

%files
    requirements.txt /

%post
    pip3 install -r /requirements.txt
    pip3 install --no-build-isolation --no-deps xformers==0.0.30

    # Verify xformers installation
    python3 -c "import xformers; print(f'xformers version: {xformers.__version__}')" || echo "xformers import failed"


%labels
    Maintainer "NHR@FAU"
    Version 1.1
    Description "NVIDIA CUDA 12.9 PyTorch Container with GPU Support"

%runscript
    # Execute python script passed as arguments
    exec python3 "$@"


# Build the container (located in computer vision directory)
# apptainer build save_path/nvidia_cuda12_9_xformers.sif scripts/environment/nvidia_cuda12_9_xformers.def
